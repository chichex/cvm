{
  "env": {
    "CVM_MAINTAIN_MIN_ENTRIES": "8",
    "CVM_MAINTAIN_STALE_THRESHOLD": "3",
    "CVM_MAINTAIN_SESSION_THRESHOLD": "5",
    "CVM_EVOLVE_TAG_THRESHOLD": "6",
    "CVM_EVOLVE_SESSION_THRESHOLD": "3",
    "SDD_SPECS_DIR": "specs",
    "CVM_CONTEXT_ENTRY_COUNT": "10",
    "CVM_CONTEXT_MAX_TOKENS": "2000",
    "CVM_AUTOSUMMARY_ENABLED": "true",
    "CVM_AUTOSUMMARY_MODEL": "haiku",
    "CVM_OBSERVE_TOOLS": "Bash,Write,Edit"
  },
  "permissions": {
    "allow": [
      "Bash(cvm *)",
      "Bash(chmod +x *)",
      "Bash(which *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(npx *)",
      "Bash(codex *)",
      "Bash(gemini *)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/session-start.sh" },
          { "type": "command", "command": "bash ~/.claude/hooks/check-tools.sh" },
          { "type": "command", "command": "bash ~/.claude/hooks/context-inject.sh" }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/post-compaction.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/learning-decorator.sh" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/subagent-stop.sh", "timeout": 10000 }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/session-end.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/config-protection.sh" },
          { "type": "command", "command": "bash ~/.claude/hooks/spec-guard.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/tool-observe.sh" }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/slop-check.sh" }
        ]
      }
    ]
  },
  "effortLevel": "high",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  }
}
