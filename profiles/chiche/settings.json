{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(cvm *)",
      "Bash(chmod +x:*)",
      "Bash(which *)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cvm lifecycle start"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/check-tools.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "La sesion esta por terminar. Si durante esta sesion descubriste algo no obvio (un gotcha, un learning, una decision de diseno), persistilo ahora usando los comandos `cvm kb put`. Revisar brevemente la conversacion y extraer lo que valga la pena guardar. Si no hay nada relevante, continuar sin hacer nada."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cvm lifecycle end"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/config-protection.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/slop-check.sh"
          }
        ]
      }
    ]
  },
  "effortLevel": "high",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  }
}
